# Copy this file to ~/.lumen/.env and fill in your keys.
# Lumen always reads ~/.lumen/.env regardless of LUMEN_DIR.

# Required for compile, ask, enrich (pick one provider)
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# Optional: for vector embeddings (lumen embed)
# OPENAI_API_KEY=sk-...
