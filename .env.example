# Copy this file to ~/.lumen/.env and fill in your keys.
#
# Load order (first-write-wins — earlier files take priority):
#   1. $LUMEN_DIR/.env   (workspace-specific, if LUMEN_DIR is set)
#   2. $PWD/.env         (project-local dev override)
#   3. ~/.lumen/.env     (fallback — always checked so API keys are found)

# Required for compile, ask, enrich (pick one provider)
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# Optional: for vector embeddings (lumen embed)
# OPENAI_API_KEY=sk-...
