    },
    "devDependencies": {
        "@lumen/eslint-config": "workspace:*",
        "@lumen/tsconfig": "workspace:*",
        "@types/node": "^22.13.10",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "eslint": "^9.17.0",
        "eslint-config-next": "^15.5.0",
        "typescript": "^5.8.2"
    }
