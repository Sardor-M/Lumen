{
    "name": "@lumen/landing",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev -p 3001",
        "build": "next build",
        "start": "next start -p 3001",
        "lint": "next lint && tsc --noEmit",
        "format": "prettier --write \"src/**/*.{ts,tsx}\"",
