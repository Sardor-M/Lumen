{
    "name": "@lumen/cli",
    "version": "0.1.0",
    "description": "Lumen CLI — ingest, chunk, search, and compile reading into a structured knowledge graph",
    "type": "module",
    "bin": {
        "lumen": "./dist/cli.js"
    },
    "exports": {
        ".": "./src/index.ts",
        "./tools": "./src/tools.ts",
        "./openai": "./src/adapters/openai.ts",
        "./ai-sdk": "./src/adapters/ai-sdk.ts",
        "./mastra": "./src/adapters/mastra.ts",
        "./langchain": "./src/adapters/langchain.ts",
        "./store/*": "./src/store/*.ts",
        "./search/*": "./src/search/*.ts",
        "./graph/*": "./src/graph/*.ts",
        "./profile/*": "./src/profile/*.ts",
        "./types": "./src/types/index.ts",
        "./utils/paths": "./src/utils/paths.ts"
    },
    "scripts": {
        "dev": "tsx src/cli.ts",
        "build": "tsup src/cli.ts --format esm --dts --clean",
        "start": "node dist/cli.js",
        "lint": "eslint src/ && tsc --noEmit",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "test": "vitest run",
        "test:watch": "vitest",
        "benchmark": "tsx src/cli.ts benchmark",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.39.0",
        "@extractus/article-extractor": "^8.0.14",
        "@extractus/feed-extractor": "^7.1.7",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "better-sqlite3": "^12.0.0",
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "ora": "^8.2.0",
        "pdf-parse": "^1.1.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22.13.10",
        "@types/pdf-parse": "^1.1.4",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.1.8",
        "tsup": "^8.4.0",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2",
        "vitest": "^3.1.1"
    }
}
