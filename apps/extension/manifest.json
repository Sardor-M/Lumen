{
    "manifest_version": 3,
    "name": "Lumen",
    "version": "0.1.0",
    "description": "One-click ingest the current page into your Lumen knowledge base.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Lumen — Ingest this page"
    },
    "permissions": ["activeTab", "scripting"],
    "host_permissions": ["http://localhost:3000/*"],
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    }
}
